# Copy to deploy/.env (gitignored) or set these directly as Portainer stack
# environment variables — do not commit real values.
RCON_PASSWORD=
AMP_HOST=
AMP_USER=
AMP_SAVE_ROOT=
AMP_WORLD_GUID=
# Only needed if the private key isn't at the docker-compose.yml default
# path (./deploy/paldex_deploy_key relative to the compose file).
PALDEX_SSH_KEY_HOST_PATH=
