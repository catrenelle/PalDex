# Copy this file to backend/secrets.py (gitignored — never commit real
# values there) and fill in your own. This is the local-dev fallback path;
# env vars always take priority when both are set (see backend/config.py).
# Equivalent to deploy/.env.example, just as Python assignments instead of
# KEY=value lines. See README.md's "Running locally" and deploy/README.md /
# deploy/bare-metal.md for what each of these is and how to obtain it.

RCON_PASSWORD = ""
AMP_HOST = ""
AMP_USER = ""
AMP_SAVE_ROOT = ""  # trailing slash matters -- rsync source semantics
AMP_WORLD_GUID = ""

# Only needed outside Docker (see deploy/bare-metal.md) -- the private key
# path backend/remote.py's Linux SSH path reads from. Leave commented out
# for local Windows dev, which uses the Bitvise SSH Client instead and
# doesn't read this at all.
# PALDEX_SSH_KEY = "/path/to/paldex_deploy_key"
